{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-zen": {
      "name": "opencode-zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "big-pickle": {
          "name": "big-pickle"
        }
      }
    },
    "z.ai-cn": {
      "name": "z.ai-cn",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "{env:Z_AI_CN_API_KEY}"
      },
      "models": {
        "glm-4.5-flash": {
          "name": "glm-4.5-flash"
        },
        "glm-4.7-flash": {
          "name": "glm-4.7-flash"
        },
        "glm-4.7": {
          "name": "glm-4.7"
        }
      }
    }
  },
  "plugin": [
    "oh-my-opencode@3.14.0"
  ],
  "watcher": {
    "ignore": [
      ".idea",
      ".git",
      "node_modules",
      "logs",
      "bun.lock"
    ]
  }
}
