{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "z.ai": {
      "name": "z.ai",
      "options": {
        "baseURL": "https://api.z.ai/api/paas/v4",
        "apiKey": "{env:Z_AI_API_KEY}"
      },
      "models": {
        "glm-4.5-flash": {
          "name": "glm-4.5-flash"
        },
        "glm-4.7-flash": {
          "name": "glm-4.7-flash"
        }
      }
    },
    "z.ai-cn": {
      "name": "z.ai-cn",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": "{env:Z_AI_CN_API_KEY}"
      },
      "models": {
        "glm-4.5-flash": {
          "name": "glm-4.5-flash"
        },
        "glm-4.7-flash": {
          "name": "glm-4.7-flash"
        }
      }
    }
  },
  "plugin": [
    "oh-my-opencode"
  ]
}
